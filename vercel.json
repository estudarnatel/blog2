{
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        },
        {
        "src": "index.html",
        "use": "@vercel/static"
        },
        {
        "src": "CSS/**",
        "use": "@vercel/static"
        },
        {
        "src": "JS/**",
        "use": "@vercel/static"
        }
    ],
    "routes": [        
        {
            "src": "/api/(.*)",
            "dest": "api/index.py"
        }
    ]
}
